# ============================================================
# Layer 1: IP Whitelist — blocks all traffic outside allowed range
# ============================================================
<IfModule mod_authz_core.c>
    # Apache 2.4+
    Require ip 145.117.0.0/16
    Require ip 127.0.0.1
    Require ip ::1
</IfModule>
<IfModule !mod_authz_core.c>
    # Apache 2.2 fallback
    Order deny,allow
    Deny from all
    Allow from 145.117.0.0/16
    Allow from 127.0.0.1
    Allow from ::1
</IfModule>

# ============================================================
# Layer 2: Apache Basic Auth — server-level password prompt
# ============================================================
<IfModule mod_authn_file.c>
    AuthType Basic
    AuthName "RubyNU Server Access"
    AuthUserFile ${DOCUMENT_ROOT}/../storage/app/adminer/.htpasswd-server
    Require valid-user
</IfModule>

# ============================================================
# File Protection
# ============================================================
# Prevent direct access to sensitive files (.htaccess, .htpasswd, etc.)
<FilesMatch "^\.ht">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block direct access to the Adminer Core engine
<FilesMatch "\.core$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Security headers for DB tool
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "no-referrer"
    Header set Cache-Control "no-store, no-cache, must-revalidate"
</IfModule>
