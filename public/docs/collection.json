                    "name": "Check if the authenticated participant exists.",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/pbac\/check",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/v1\/pbac\/check"
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": null,
                        "description": "**Requires authentication via Bearer token in the Authorization header.**"
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"success\": true,\n  \"message\": \"Participant found.\",\n  \"data\": { \"id\": 1, \"registration_number\": \"12345\", ... }\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 401,
                            "body": "{\n  \"success\": false,\n  \"message\": \"Authentication required. Please provide a valid Bearer token.\",\n  \"data\": null\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 404,
                            "body": "{\n  \"success\": false,\n  \"message\": \"Participant not found.\",\n  \"data\": null\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 500,
                            "body": "{\n  \"success\": false,\n  \"message\": \"<error message>\",\n  \"data\": null\n}",
                            "name": ""
                        }
                    ]
                },
