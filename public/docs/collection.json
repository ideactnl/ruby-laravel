    "info": {
        "name": "RubyNU API Documentation",
        "_postman_id": "97680a9c-2497-4764-b2f4-727cfc8db671",
        "description": "Welcome to the RubyNU API documentation. This API provides a comprehensive set of endpoints for managing users, authentication, and application resources. All endpoints requiring authentication are secured with Bearer Tokens, which you can obtain via the registration or login endpoints. Explore the available routes for detailed information on request parameters, response formats, and error handling. For further assistance or questions, please contact the development team.",
        "schema": "https:\/\/schema.getpostman.com\/json\/collection\/v2.1.0\/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "description": "\nAuthentication and user management endpoints.",
            "item": [
                {
                    "name": "Register a new user.",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/register",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/v1\/register"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"registration_number\":\"user123\",\"pin\":\"123456\",\"opt_in_for_research\":true}"
                        },
                        "description": "Registers a user with a registration number, PIN, and agreement to share data for research.",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 201,
                            "body": "{\n  \"success\": true,\n  \"message\": \"Registration successful\",\n  \"data\": {\n    \"user\": { \"id\": 1, \"registration_number\": \"user123\", ... },\n    \"access_token\": \"1|abcdef...\"\n  }\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 400,
                            "body": "{\n  \"success\": false,\n  \"message\": \"Registration failed: <error message>\",\n  \"data\": null\n}",
                            "name": ""
                        }
                    ]
                },
                {
                    "name": "Login (PIN-based)",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/login",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/v1\/login"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"registration_number\":\"user123\",\"pin\":\"123456\"}"
                        },
                        "description": "Authenticates a user using registration number and PIN. Returns a Sanctum Bearer access_token for API access.",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"success\": true,\n  \"message\": \"Login successful\",\n  \"data\": {\n    \"user\": { ... },\n    \"access_token\": \"1|abcdef...\"\n  }\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 401,
                            "body": "{\n  \"success\": false,\n  \"message\": \"Invalid credentials\",\n  \"data\": null\n}",
                            "name": ""
                        }
                    ]
                },
                {
                    "name": "Update user profile (toggles, password)",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/profile",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/v1\/profile"
                        },
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"enable_data_sharing\":true,\"opt_in_for_research\":false,\"password\":\"mysecurepassword\",\"pin\":\"123456\"}"
                        },
                        "description": "Updates the authenticated user's profile toggles and\/or password. Password change requires correct PIN.\n\n**Requires authentication via Bearer token in the Authorization header.**"
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"success\": true,\n  \"message\": \"Profile updated successfully\",\n  \"data\": { \"user\": { ... } }\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 401,
                            "body": "{\n  \"success\": false,\n  \"message\": \"Unauthenticated.\",\n  \"data\": null\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 403,
                            "body": "{\n  \"success\": false,\n  \"message\": \"Invalid pin\",\n  \"data\": null\n}",
                            "name": ""
                        }
                    ]
                },
                {
                    "name": "Logout (revoke token)",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/logout",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/v1\/logout"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": null,
                        "description": "Logs out the authenticated user by revoking the current Sanctum Bearer token.\n\n**Requires authentication via Bearer token in the Authorization header.**"
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"success\": true,\n  \"message\": \"Logged out successfully\",\n  \"data\": null\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 401,
                            "body": "{\n  \"success\": false,\n  \"message\": \"Unauthenticated.\",\n  \"data\": null\n}",
                            "name": ""
                        }
                    ]
                },
                {
                    "name": "Get login logs for a registration number.",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/login-logs",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/v1\/login-logs"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"registration_number\":\"user123\"}"
                        },
                        "description": "Returns login logs for the given registration number.",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"success\": true,\n  \"message\": \"Logs retrieved successfully.\",\n  \"data\": [\n    {\"id\": 1, \"registration_number\": \"user123\", \"login_at\": \"2025-07-02T11:00:00\"}\n  ]\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 404,
                            "body": "{\n  \"success\": false,\n  \"message\": \"No logs found for this registration number.\",\n  \"data\": null\n}",
                            "name": ""
                        }
                    ]
                }
            ]
        },
        {
            "name": "PBAC",
            "description": "Endpoints related to PBAC records and participant management.",
            "item": [
                {
                    "name": "Filter PBAC records for the authenticated user by day, month, and\/or year.",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/pbac\/filter",
                            "query": [
                                {
                                    "key": "day",
                                    "value": "3",
                                    "description": "optional The day to filter.",
                                    "disabled": false
                                },
                                {
                                    "key": "month",
                                    "value": "7",
                                    "description": "optional The month to filter.",
                                    "disabled": false
                                },
                                {
                                    "key": "year",
                                    "value": "2025",
                                    "description": "optional The year to filter.",
                                    "disabled": false
                                }
                            ],
                            "raw": "{{baseUrl}}\/api\/v1\/pbac\/filter?day=3&month=7&year=2025"
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"day\":16,\"month\":16,\"year\":16}"
                        },
                        "description": "**Requires authentication via Bearer token in the Authorization header.**"
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"success\": true,\n  \"message\": \"PBAC records retrieved successfully.\",\n  \"data\": [ { \"ReportedDate\": \"2025-07-01\", ... } ]\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 401,
                            "body": "{\n  \"success\": false,\n  \"message\": \"Authentication required. Please provide a valid Bearer token.\",\n  \"data\": null\n}",
                            "name": ""
                        }
                    ]
                },
